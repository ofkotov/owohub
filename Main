                            petCount = tonumber(input) or 1
                            warn("Pet count set to:", petCount)
                        end
                    )
                end
            }
        )


        PetsTab:Button(
            {
                Title = "Spawn Pet",
                Icon = "sparkles",
                Callback = function()
                    task.spawn(
                        function()
                            if not petName or petName == "" then
                                warn("Please enter a pet name!")
                                return
                            end
                            local petId = GetPetByName(petName)
                            if not petId then
                                warn("Pet not found!")
                                WindUI:Notify(
                                    {
                                        Title = "Error",
                                        Content = "Pet Not Found Please Try Again",
                                        Icon = "shield-alert",
                                        Duration = 2
                                    }
                                )
                                return
                            end
                            for i = 1, petCount do
                                local props = {
                                    pet_trick_level = 0,
