                                    rp_name = ""
                                }

                                if petType == "NFR" then
                                    props.neon = true
                                elseif petType == "MFR" then
                                    props.mega_neon = true
                                end
                                createPet(petId, props)
                            end
                        end
                    )
                    WindUI:Notify(
                        {
                            Title = "Spawning Item",
