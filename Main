                            Icon = "loader",
                            Duration = 2
                        }
                    )
                end
            }
        )


        -- === PET MODEL SWAP (workspace-wide, works on all players' pets) ===
        local swapRules = {} -- fromModelName -> {toKind=..., fromKind=...}
        local swappedModels = {} -- track already-swapped model instances
        local swapFromName = nil
        local swapToName = nil
        local swapType = "FR"

        -- Resolve a kind to its actual model name
        local function getModelNameForKind(kind)
            local model = getPetModel(kind)
            return model and model.Name or kind
        end

        -- Hide ALL visible elements in a model (optionally rename nametags instead of hiding)
        local function hideModelParts(model, newDisplayName)
            for _, desc in ipairs(model:GetDescendants()) do
                if desc:IsA("BasePart") then
                    desc.Transparency = 1
                    desc.CanCollide = false
                elseif desc:IsA("Decal") or desc:IsA("Texture") then
                    desc.Transparency = 1
                elseif desc:IsA("BillboardGui") then
                    -- If we have a new name, update name labels instead of hiding
                    if newDisplayName and newDisplayName ~= "" then
                        for _, child in ipairs(desc:GetDescendants()) do
                            if child:IsA("TextLabel") or child:IsA("TextButton") then
                                child.Text = newDisplayName
                            end
                        end
                    else
                        desc.Enabled = false
                    end
                elseif desc:IsA("SurfaceGui") then
                    desc.Enabled = false
                elseif desc:IsA("ParticleEmitter") or desc:IsA("Trail") or desc:IsA("Beam") then
                    desc.Enabled = false
                end
            end
        end

        -- Rename original pet in pet_char_wrappers (changes the name the game displays)
        local function renameOriginalPetWrapper(model, newName, newPetId)
            pcall(function()
                set_thread_identity(2)
                local wrappers = clientData.get("pet_char_wrappers")
                for i, wrapper in pairs(wrappers) do
                    if wrapper.char == model then
                        local clonedWrappers = table.clone(wrappers)
                        clonedWrappers[i] = table.clone(clonedWrappers[i])
                        clonedWrappers[i].rp_name = newName
                        if newPetId then
                            clonedWrappers[i].pet_id = newPetId
                        end
                        clientData.predict("pet_char_wrappers", clonedWrappers)
                        warn("[Swap] Renamed original wrapper to: " .. newName)
                        break
                    end
                end
                set_thread_identity(8)
            end)
        end

        -- Find a root part in a model (HumanoidRootPart or PrimaryPart or first BasePart)
        local function findRootPart(model)
            local hrp = model:FindFirstChild("HumanoidRootPart", true)
            if hrp then return hrp end
            if model.PrimaryPart then return model.PrimaryPart end
            for _, d in ipairs(model:GetDescendants()) do
                if d:IsA("BasePart") then return d end
            end
            return nil
        end

        -- Apply a swap rule to a single model in workspace
        local function trySwapModel(model)
            if not model:IsA("Model") then return end
            if swappedModels[model] then return end
            if model.Name == "_SwapOverlay" then return end  -- don't swap our own overlays
            if not model:FindFirstChild("PetModel") then return end

            -- Check all swap rules by model name
            local rule = swapRules[model.Name]
            if rule then
                local ok, err = pcall(function()
                    -- Get display name for the new pet
                    local newDisplayName = rule.toName or ""

                    -- Hide ALL parts of the original model, but rename nametags
                    hideModelParts(model, newDisplayName)

                    -- Rename the original pet's wrapper in pet_char_wrappers
                    renameOriginalPetWrapper(model, newDisplayName, rule.toId)

                    -- Cleanup function for swap overlays
                    local function cleanupSwapOverlay(prevData)
                        if prevData.syncConn then prevData.syncConn:Disconnect() end
                        if prevData.overlay and prevData.overlay.Parent then prevData.overlay:Destroy() end
                        -- Remove wrapper from pet system
                        if prevData.swapUnique then
                            pcall(function()
                                set_thread_identity(2)
                                removePetWrapper(prevData.swapUnique)
                                set_thread_identity(8)
                            end)
                        end
                    end

                    -- Remove any previous swap overlay
                    local prev = swappedModels[model]
                    if prev then
                        cleanupSwapOverlay(prev)
                        swappedModels[model] = nil
                    end

                    -- Clone the ENTIRE new pet model
                    local newFullModel = getPetModel(rule.toKind):Clone()
                    newFullModel.Name = "_SwapOverlay"

                    -- Apply neon if specified
                    if rule.neonType == "NFR" or rule.neonType == "MFR" then
                        local neonOk, neonErr = pcall(function()
                            set_thread_identity(2)
                            local entry = items[rule.toId] or items[rule.toKind]
                            if entry and entry.neon_parts then
                                neonify(newFullModel, entry)
                            end
                            set_thread_identity(8)
                        end)
                        if not neonOk then warn("[Swap] Neon error: " .. tostring(neonErr)) end
                    end

                    -- Parent to WORKSPACE directly (not nested!) so Roblox auto-animates
                    newFullModel:PivotTo(model:GetPivot())
                    newFullModel.Parent = workspace

                    -- Make all parts in overlay non-collidable, no hitbox, massless
                    for _, part in ipairs(newFullModel:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                            part.CanQuery = false
                            part.CanTouch = false
                            part.Massless = true
                            part.Anchored = false
                        end
                    end

                    -- Sync position via Heartbeat (follows original pet every frame)
                    local RunService = game:GetService("RunService")
                    local syncConn
                    syncConn = RunService.Heartbeat:Connect(function()
                        if not model.Parent or not newFullModel.Parent then
                            syncConn:Disconnect()
                            -- Cleanup overlay and wrapper
                            local tracked = swappedModels[model]
                            if tracked then
                                tracked.syncConn = nil -- already disconnected
                                cleanupSwapOverlay(tracked)
                                swappedModels[model] = nil
                            elseif newFullModel.Parent then
                                newFullModel:Destroy()
                            end
                            return
                        end
                        pcall(function()
                            newFullModel:PivotTo(model:GetPivot())
                        end)
                    end)

                    -- MFR rainbow color cycling
                    if rule.neonType == "MFR" then
                        task.spawn(function()
                            -- Collect all neon-material parts
                            local neonParts = {}
                            for _, part in ipairs(newFullModel:GetDescendants()) do
                                if part:IsA("BasePart") and part.Material == Enum.Material.Neon then
                                    table.insert(neonParts, part)
                                end
                            end
                            warn("[Swap] MFR rainbow on " .. #neonParts .. " neon parts")
                            -- Rainbow cycle loop
                            local hue = 0
                            while newFullModel and newFullModel.Parent do
                                hue = (hue + 0.005) % 1
                                local color = Color3.fromHSV(hue, 1, 1)
                                for _, part in ipairs(neonParts) do
                                    pcall(function() part.Color = color end)
                                end
                                task.wait(0.03)
                            end
                        end)
                    end

                    -- Generate unique ID for wrapper tracking
                    local swapUnique = getUniqueId()

                    -- Register overlay with game's pet animation system
                    local animOk, animErr = pcall(function()
                        set_thread_identity(2)
                        addPetWrapper(
                            {
                                char = newFullModel,
                                mega_neon = rule.neonType == "MFR",
                                neon = rule.neonType == "NFR" or rule.neonType == "MFR",
                                player = game.Players.LocalPlayer,
                                entity_controller = game.Players.LocalPlayer,
                                controller = game.Players.LocalPlayer,
                                rp_name = rule.toName or "",
                                pet_trick_level = 0,
                                pet_unique = swapUnique,
                                pet_id = rule.toId,
                                location = {
                                    full_destination_id = "housing",
                                    destination_id = "housing",
                                    house_owner = game.Players.LocalPlayer
                                },
                                pet_progression = {
                                    friendship_level = 0,
                                    age = "Post-Teen",
                                    percentage = 0
                                },
                                are_colors_sealed = false,
                                is_pet = true
                            }
                        )
                        addPetState(
                            {
                                char = newFullModel,
                                player = game.Players.LocalPlayer,
                                store_key = "pet_state_managers",
                                is_sitting = false,
                                chars_connected_to_me = {},
                                states = {}
                            }
                        )
                        set_thread_identity(8)
                        warn("[Swap] Registered overlay with pet animation system (id=" .. swapUnique .. ")")
                    end)
                    if not animOk then warn("[Swap] Animation registration error: " .. tostring(animErr)) end

                    swappedModels[model] = {rule = rule, overlay = newFullModel, syncConn = syncConn, swapUnique = swapUnique}
                    warn("[Swap] Swapped: " .. model.Name .. " -> " .. rule.toKind .. " (" .. rule.neonType .. ")")

                    -- Watch for game re-adding ANY visual parts to original (hide them, rename nametags)
                    model.DescendantAdded:Connect(function(desc)
                        if not swappedModels[model] then return end
                        local currentRule = swappedModels[model].rule
                        local displayName = currentRule and currentRule.toName or ""
                        task.defer(function()
                            pcall(function()
                                if desc:IsA("BasePart") then
                                    desc.Transparency = 1
                                    desc.CanCollide = false
                                elseif desc:IsA("Decal") or desc:IsA("Texture") then
                                    desc.Transparency = 1
                                elseif desc:IsA("BillboardGui") then
                                    -- Update name labels with the swapped name
                                    if displayName ~= "" then
                                        for _, child in ipairs(desc:GetDescendants()) do
                                            if child:IsA("TextLabel") or child:IsA("TextButton") then
                                                child.Text = displayName
                                            end
                                        end
                                    else
                                        desc.Enabled = false
                                    end
                                elseif desc:IsA("SurfaceGui") then
                                    desc.Enabled = false
                                elseif desc:IsA("ParticleEmitter") or desc:IsA("Trail") or desc:IsA("Beam") then
                                    desc.Enabled = false
                                elseif (desc:IsA("TextLabel") or desc:IsA("TextButton")) and displayName ~= "" then
                                    -- Catch TextLabels added inside existing BillboardGuis
                                    if desc.Parent and desc.Parent:IsA("BillboardGui") then
                                        desc.Text = displayName
                                    end
                                end
                            end)
                        end)
                    end)
                end)
                if not ok then warn("[Swap] Error: " .. tostring(err)) end
            end
        end

        -- Scan entire workspace for existing models and apply rules
        local function scanWorkspaceForSwaps()
            for _, obj in ipairs(workspace:GetDescendants()) do
                trySwapModel(obj)
            end
        end

        -- Watch for new models appearing in workspace (pet model or the container)
        workspace.DescendantAdded:Connect(function(desc)
            task.defer(function()
                if desc:IsA("Model") then
                    trySwapModel(desc)
                elseif desc.Name == "PetModel" and desc.Parent and desc.Parent:IsA("Model") then
                    trySwapModel(desc.Parent)
                end
            end)
        end)

        local SecretTab =
            Window:Tab(
            {
                Title = "Secret Spawner",
                Icon = "lock",
                Desc = "Spawn all pets by rarity"
            }
        )

        SecretTab:Paragraph(
            {
                Title = "Secret Spawner",
                Desc = "Spawn all pets from the game by rarity",
                Image = "lock",
                Color = "HotPink"
            }
        )

        SecretTab:Dropdown(
            {
                Title = "Rarity",
                Values = {"All", "Common", "Uncommon", "Rare", "Ultra-Rare", "Legendary"},
                Multi = false,
                Default = "All",
                Callback = function(value)
                    task.spawn(
                        function()
                            if value == nil then return end
                            petRarity = value
                            warn("Rarity set to:", petRarity)
                        end
                    )
                end
            }
        )

        SecretTab:Dropdown(
            {
                Title = "Type",
                Values = {"FR", "NFR", "MFR"},
                Multi = false,
                Default = "FR",
                Callback = function(value)
                    task.spawn(
                        function()
                            if value == nil then return end
                            petType = value
                            warn("Pet type set to:", petType)
                        end
                    )
                end
            }
        )

        SecretTab:Button(
            {
                Title = "Spawn ALL Pets",
                Icon = "rocket",
                Callback = function()
                    task.spawn(
                        function()
                            -- 1. Collect pets matching rarity
                            local matchingPets = {}
                            local rarityNum = {
                                ["Common"] = 1,
                                ["Uncommon"] = 2,
                                ["Rare"] = 3,
                                ["Ultra-Rare"] = 4,
                                ["Legendary"] = 5
                            }
                            for _, petData in pairs(InventoryDB.pets) do
                                local dominated = true
                                if petRarity ~= "All" then
                                    local r = petData.rarity
                                    local match = false
                                    if type(r) == "number" and r == rarityNum[petRarity] then
                                        match = true
                                    end
                                    if type(r) == "string" then
                                        local norm1 = r:lower():gsub("[%s%-_]", "")
                                        local norm2 = petRarity:lower():gsub("[%s%-_]", "")
                                        if norm1 == norm2 then
                                            match = true
                                        end
                                    end
                                    if not match then
                                        dominated = false
                                    end
                                end
                                if dominated then
                                    -- Skip eggs
                                    local name = (petData.name or petData.id or ""):lower()
                                    local kind = (petData.kind or ""):lower()
                                    if kind == "egg" or name:find("egg") then
                                        dominated = false
                                    end
                                end
                                if dominated then
                                    -- Skip non-tradeable pets
                                    if petData.tradeable == false or petData.tradable == false or petData.is_tradeable == false then
                                        dominated = false
                                    end
                                    -- Also check via KindDB items entry
                                    if dominated and petData.id then
                                        local entry = items[petData.id]
                                        if entry and (entry.tradeable == false or entry.tradable == false or entry.is_tradeable == false) then
                                            dominated = false
                                        end
                                    end
                                end
                                if dominated then
                                    table.insert(matchingPets, petData)
                                end
                            end

                            -- 2. Shuffle (Fisher-Yates)
                            for i = #matchingPets, 2, -1 do
                                local j = math.random(1, i)
                                matchingPets[i], matchingPets[j] = matchingPets[j], matchingPets[i]
                            end

                            -- 3. Take 1/3
                            local takeCount = math.max(1, math.floor(#matchingPets / 3))
                            local selected = {}
                            for i = 1, takeCount do
                                table.insert(selected, matchingPets[i])
                            end

                            -- 4. Spawn 1-3 copies of each
                            local count = 0
                            for _, petData in ipairs(selected) do
                                local copies = math.random(1, 3)
                                for c = 1, copies do
                                    local ok, err = pcall(function()
                                        local props = {
                                            pet_trick_level = 0,
                                            rideable = true,
                                            flyable = true,
                                            friendship_level = 0,
                                            age = 1,
                                            rp_name = ""
                                        }
                                        if petType == "NFR" then
                                            props.neon = true
                                        elseif petType == "MFR" then
                                            props.mega_neon = true
                                        end
                                        createPet(petData.id, props)
                                        count = count + 1
                                    end)
                                    if not ok then
                                        warn("Failed to spawn:", petData.name, err)
                                    end
                                end
                            end
                            WindUI:Notify(
                                {
                                    Title = "Done!",
                                    Content = "Spawned " .. count .. " pets from " .. #selected .. "/" .. #matchingPets .. " " .. petRarity .. " (" .. petType .. ")",
                                    Icon = "check",
                                    Duration = 5
                                }
                            )
                        end
                    )
                    WindUI:Notify(
                        {
                            Title = "Spawning " .. petRarity .. " Pets",
                            Content = "Randomizing 1/3 of pets...",
                            Icon = "loader",
                            Duration = 3
                        }
                    )
                end
            }
        )

        -- Dev Tab
        local DevTab =
            Window:Tab(
            {
                Title = "Dev",
                Icon = "code",
                Desc = "Developer tools"
            }
        )

        DevTab:Paragraph(
            {
                Title = "Pet Model Swap",
                Desc = "Replace pet visuals for ALL players (you see the swap)",
                Image = "repeat",
                Color = "HotPink"
            }
        )

        DevTab:Input(
            {
                Title = "Original Pet",
                Value = "",
                InputIcon = "search",
                Placeholder = "Pet to replace...",
                Callback = function(input)
                    task.spawn(function()
                        swapFromName = input
                        warn("[Swap] From:", swapFromName)
                    end)
                end
            }
        )

        DevTab:Input(
            {
                Title = "Replace With",
                Value = "",
                InputIcon = "search",
                Placeholder = "New visual pet...",
                Callback = function(input)
                    task.spawn(function()
                        swapToName = input
                        warn("[Swap] To:", swapToName)
                    end)
                end
            }
        )

        DevTab:Dropdown(
            {
                Title = "Swap Type",
                Values = {"FR", "NFR", "MFR"},
                Multi = false,
                Default = "FR",
                Callback = function(value)
                    task.spawn(function()
                        if value == nil then return end
                        swapType = value
                        warn("[Swap] Type:", swapType)
                    end)
                end
            }
        )

        DevTab:Button(
            {
                Title = "Add Swap Rule",
                Icon = "plus",
                Callback = function()
                    task.spawn(function()
                        if not swapFromName or swapFromName == "" then
                            WindUI:Notify({Title = "Error", Content = "Enter original pet name", Icon = "shield-alert", Duration = 2})
                            return
                        end
                        if not swapToName or swapToName == "" then
                            WindUI:Notify({Title = "Error", Content = "Enter replacement pet name", Icon = "shield-alert", Duration = 2})
                            return
                        end

                        local fromId = GetPetByName(swapFromName)
                        if not fromId then
                            WindUI:Notify({Title = "Error", Content = "Pet '" .. swapFromName .. "' not found", Icon = "shield-alert", Duration = 2})
                            return
                        end
                        local toId = GetPetByName(swapToName)
                        if not toId then
                            WindUI:Notify({Title = "Error", Content = "Pet '" .. swapToName .. "' not found", Icon = "shield-alert", Duration = 2})
                            return
                        end

                        local fromKind = items[fromId] and items[fromId].kind
                        local toKind = items[toId] and items[toId].kind
                        if not fromKind or not toKind then
                            WindUI:Notify({Title = "Error", Content = "Could not resolve pet kinds", Icon = "shield-alert", Duration = 2})
                            return
                        end

                        -- Resolve actual model name (not kind string)
                        local fromModelName = getModelNameForKind(fromKind)
                        swapRules[fromModelName] = {toKind = toKind, toId = toId, fromKind = fromKind, neonType = swapType, toName = swapToName}
                        warn("[Swap] Rule added: " .. fromModelName .. " (" .. fromKind .. ") -> " .. toKind)

                        -- Immediately apply to all existing models in workspace
                        scanWorkspaceForSwaps()

                        local ruleCount = 0
                        for _ in pairs(swapRules) do ruleCount = ruleCount + 1 end
                        set_thread_identity(8)
                        WindUI:Notify({
                            Title = "Rule Added!",
                            Content = swapFromName .. " → " .. swapToName .. " (Active rules: " .. ruleCount .. ")",
                            Icon = "check",
                            Duration = 3
                        })
                    end)
                end
            }
        )

        DevTab:Button(
            {
                Title = "Clear All Rules",
                Icon = "trash-2",
                Callback = function()
                    task.spawn(function()
                        swapRules = {}
                        swappedModels = {}
                        warn("[Swap] All rules cleared")
                        WindUI:Notify({Title = "Cleared", Content = "All swap rules removed", Icon = "check", Duration = 2})
                    end)
                end
            }
        )

        DevTab:Button(
            {
                Title = "Delete All Fake Pets",
                Icon = "trash-2",
                Callback = function()
                    task.spawn(function()
                        local deleted = 0
                        -- Unequip if current equipped pet is fake
                        if equippedPet and equippedPet._fake then
                            pcall(function() unequip(equippedPet) end)
                        end
                        -- Remove all fake pets from inventory and destroy models
                        for uid, petEntry in pairs(pets) do
                            if fakePetIds[uid] then
                                -- Destroy model if exists
                                if petEntry.model and petEntry.model.Parent then
                                    pcall(function()
                                        removePetWrapper(uid)
                                        removePetState(uid)
                                        petEntry.model:Destroy()
                                    end)
                                end
                                deleted = deleted + 1
                            end
                        end
                        -- Remove from inventory data
                        pcall(function()
                            set_thread_identity(2)
                            updateData("inventory", function(inventory)
                                local newPets = table.clone(inventory.pets)
                                for uid, _ in pairs(fakePetIds) do
                                    newPets[uid] = nil
                                end
                                inventory.pets = newPets
                                return inventory
                            end)
                            set_thread_identity(8)
                        end)
                        -- Clear tracking tables
                        for uid, _ in pairs(fakePetIds) do
                            pets[uid] = nil
                        end
                        fakePetIds = {}
                        equippedPet = nil
                        warn("[FakePet] Deleted " .. deleted .. " fake pets")
                        WindUI:Notify({
                            Title = "Deleted!",
                            Content = "Removed " .. deleted .. " fake pets",
                            Icon = "trash-2",
                            Duration = 3
                        })
                    end)
                end
            }
        )

        -- === FAVORITE ALL PETS (UNSTACK) ===
        local favoriteJobRunning = false

        DevTab:Paragraph(
            {
                Title = "Favorite (Unstack)",
                Desc = "Favorites all pets to unstack them. Runs in a loop every 1 second.",
                Image = "star",
                Color = "HotPink"
            }
        )

        DevTab:Toggle(
            {
                Title = "Favorite All Pets",
                Icon = "star",
                Default = false,
                Callback = function(value)
                    task.spawn(function()
                        favoriteJobRunning = value
                        if value then
                            warn("[Favorite] Starting favorite loop...")
                            WindUI:Notify({
                                Title = "Favorite",
                                Content = "Unstacking pets — favoriting all...",
                                Icon = "star",
                                Duration = 3
                            })

                            local ReplicatedStorage = game:GetService("ReplicatedStorage")
                            local BackpackFavoriteTracker = require(ReplicatedStorage.ClientModules.Core.UIManager.Apps.BackpackApp.ItemSets.BackpackFavoriteTracker)
                            local backpack_app = load("UIManager").apps.BackpackApp

                            local function favorite_pets()
                                set_thread_identity(2)
                                local data = clientData.get("inventory")
                                for _, pet_data in data.pets do
                                    if pet_data.kind ~= "practice_dog" then
                                        if not BackpackFavoriteTracker.is_favorite(pet_data) then
                                            BackpackFavoriteTracker.set_favorite(pet_data, true)
                                        end
                                    end
                                end
                                backpack_app:refresh_rendered_items()
                                set_thread_identity(8)
                            end

                            while favoriteJobRunning do
                                pcall(favorite_pets)
                                task.wait(1)
                            end

                            warn("[Favorite] Favorite loop stopped.")
                        else
                            WindUI:Notify({
                                Title = "Favorite",
                                Content = "Stopped unstacking.",
                                Icon = "star",
                                Duration = 2
                            })
                            warn("[Favorite] Stopped.")
                        end
                    end)
                end
            }
        )

        -- === RTX NIGHT ===
        local rtxNightEnabled = false
        local rtxRenderConnection = nil
        local rtxTiltOffset = 0
        local rtxSavedLighting = nil

        local function rtxSaveOriginalLighting()
            local _Lighting = game:GetService("Lighting")
            rtxSavedLighting = {
                ClockTime = _Lighting.ClockTime,
                ColorShift_Bottom = _Lighting.ColorShift_Bottom,
                GlobalShadows = _Lighting.GlobalShadows,
                EnvironmentSpecularScale = _Lighting.EnvironmentSpecularScale,
                GeographicLatitude = _Lighting.GeographicLatitude,
                Ambient = _Lighting.Ambient,
                OutdoorAmbient = _Lighting.OutdoorAmbient,
                ExposureCompensation = _Lighting.ExposureCompensation,
                Brightness = _Lighting.Brightness,
                ColorShift_Top = _Lighting.ColorShift_Top,
                EnvironmentDiffuseScale = _Lighting.EnvironmentDiffuseScale,
                FogStart = _Lighting.FogStart,
                FogEnd = _Lighting.FogEnd,
                FogColor = _Lighting.FogColor,
            }
        end

        local function rtxEnableNight()
            local _Lighting = game:GetService("Lighting")
            local _RunService = game:GetService("RunService")
            local _UserInputService = game:GetService("UserInputService")
            local _LocalPlayer = game:GetService("Players").LocalPlayer
            local _CurrentCamera = workspace.CurrentCamera

            rtxSaveOriginalLighting()

            for _, obj in ipairs(_Lighting:GetDescendants()) do
                if obj:IsA("Atmosphere") or obj:IsA("Sky") then
                    obj:Destroy()
                end
            end

            local function rtxCreate(className)
                local inst = Instance.new(className)
                inst.Name = "RTXNight"
                inst.Parent = _Lighting
                return inst
            end
            rtxCreate("ColorCorrectionEffect").Brightness = 0.1
            rtxCreate("BloomEffect")
            rtxCreate("DepthOfFieldEffect")
            rtxCreate("SunRaysEffect")
            rtxCreate("Sky")

            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("ParticleEmitter") then
                    obj.Rate = math.max(obj.Rate, 6)
                    obj.LightEmission = 0.6
                    obj.LightInfluence = 0.3
                end
            end

            local dummyNames = {
                "P9TC2", "vA5C3", "DR9ww", "0nurp", "R94w0", "cr0VR", "3ow3N",
                "s0Gz6", "54hV8", "xB5jv", "E7FH3", "a6tIU", "78s6s", "q4f1X",
                "L8ely", "5Jdzo", "L1M60", "j2Csd", "HY59A", "OirQj", "ud7wD",
                "65fuz", "3x2n3", "EJ8Na", "hljqE", "2OXMt", "Nc4J9", "OdRmQ",
                "KvHse", "ypOq6", "Dj55d", "Y81g4", "MU2UJ", "q3H32", "lAF00",
            }
            for _, name in ipairs(dummyNames) do
                local val = Instance.new("IntValue")
                val.Name = name
                val.Parent = _Lighting
            end

            settings().Rendering.QualityLevel = Enum.QualityLevel.Level21
            _Lighting.ClockTime = 6
            _Lighting.ColorShift_Bottom = Color3.new(0, 0, 0)
            _Lighting.GlobalShadows = true
            _Lighting.EnvironmentSpecularScale = 0.255
            _Lighting.Technology = Enum.Technology.Future
            _Lighting.GeographicLatitude = -15.12
            _Lighting.Ambient = Color3.fromRGB(2, 2, 2)
            _Lighting.OutdoorAmbient = Color3.fromRGB(51, 54, 67)
            _Lighting.ExposureCompensation = 0.85
            _Lighting.Brightness = 3.25
            _Lighting.ColorShift_Top = Color3.fromRGB(255, 247, 237)
            _Lighting.EnvironmentDiffuseScale = 0.203
            _Lighting.FogStart = 0
            _Lighting.FogEnd = 1000000
            _Lighting.FogColor = Color3.new(1, 1, 1)

            for _, obj in pairs(_Lighting:GetDescendants()) do
                if obj:IsA("Atmosphere") then
                    obj:Destroy()
                end
            end

            if rtxRenderConnection then
                rtxRenderConnection:Disconnect()
            end

            local character = workspace:WaitForChild(_LocalPlayer.Name)
            local humanoid = character:WaitForChild("Humanoid")
            local head = character:WaitForChild("Head")

            rtxRenderConnection = _RunService.RenderStepped:Connect(function()
                if _CurrentCamera.CameraType ~= Enum.CameraType.Custom then return end
                if not head then return end
                if (_CurrentCamera.CFrame.Position - head.Position).Magnitude < 1 then
                    local t = tick()
                    if humanoid.MoveDirection.Magnitude <= 0 then
                        humanoid.CameraOffset = humanoid.CameraOffset * 0.75
                    else
                        local swayX = math.cos(t * 5) * 0.25
                        local swayY = math.abs(math.sin(t * 5)) * 0.25
                        humanoid.CameraOffset = humanoid.CameraOffset:Lerp(Vector3.new(swayX, swayY, 0), 0.25)
                    end
                    rtxTiltOffset = rtxTiltOffset + _UserInputService:GetMouseDelta().X * 0.05
                    _CurrentCamera.CFrame = _CurrentCamera.CFrame * CFrame.Angles(0, 0, math.rad(math.clamp(rtxTiltOffset, -6, 6)))
                else
                    humanoid.CameraOffset = Vector3.zero
                end
            end)
        end

        local function rtxDisableNight()
            local _Lighting = game:GetService("Lighting")

            if rtxRenderConnection then
                rtxRenderConnection:Disconnect()
                rtxRenderConnection = nil
            end
            rtxTiltOffset = 0

            for _, obj in ipairs(_Lighting:GetDescendants()) do
                if obj.Name == "RTXNight" then
                    obj:Destroy()
                end
            end

            if rtxSavedLighting then
                _Lighting.ClockTime = rtxSavedLighting.ClockTime
                _Lighting.ColorShift_Bottom = rtxSavedLighting.ColorShift_Bottom
                _Lighting.GlobalShadows = rtxSavedLighting.GlobalShadows
                _Lighting.EnvironmentSpecularScale = rtxSavedLighting.EnvironmentSpecularScale
                _Lighting.GeographicLatitude = rtxSavedLighting.GeographicLatitude
                _Lighting.Ambient = rtxSavedLighting.Ambient
                _Lighting.OutdoorAmbient = rtxSavedLighting.OutdoorAmbient
                _Lighting.ExposureCompensation = rtxSavedLighting.ExposureCompensation
                _Lighting.Brightness = rtxSavedLighting.Brightness
                _Lighting.ColorShift_Top = rtxSavedLighting.ColorShift_Top
                _Lighting.EnvironmentDiffuseScale = rtxSavedLighting.EnvironmentDiffuseScale
                _Lighting.FogStart = rtxSavedLighting.FogStart
                _Lighting.FogEnd = rtxSavedLighting.FogEnd
                _Lighting.FogColor = rtxSavedLighting.FogColor
                rtxSavedLighting = nil
            end

            pcall(function()
                local character = workspace:FindFirstChild(game:GetService("Players").LocalPlayer.Name)
                if character then
                    local humanoid = character:FindFirstChild("Humanoid")
                    if humanoid then
                        humanoid.CameraOffset = Vector3.zero
                    end
                end
            end)
        end

        DevTab:Toggle(
            {
                Title = "RTX Night",
                Icon = "moon",
                Default = false,
                Callback = function(value)
                    task.spawn(function()
                        rtxNightEnabled = value
                        if value then
                            warn("[RTX] Enabling RTX Night...")
                            rtxEnableNight()
                            WindUI:Notify({
                                Title = "RTX Night",
                                Content = "RTX Night enabled",
                                Icon = "moon",
                                Duration = 3
                            })
                        else
                            warn("[RTX] Disabling RTX Night...")
                            rtxDisableNight()
                            WindUI:Notify({
                                Title = "RTX Night",
                                Content = "RTX Night disabled",
                                Icon = "sun",
                                Duration = 3
                            })
                        end
                    end)
                end
            }
        )

    end
)


