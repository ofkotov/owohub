task.spawn(
    function()
        local load = require(game.ReplicatedStorage:WaitForChild("Fsys")).load

        set_thread_identity(2)
        local clientData = load("ClientData")
        local items = load("KindDB")
        local router = load("RouterClient")
        local downloader = load("DownloadClient")
        local animationManager = load("AnimationManager")
        local petRigs = load("new:PetRigs")
        set_thread_identity(8)

        local petModels = {}
        local pets = {}
        local fakePetIds = {} -- Track all fake pet unique IDs and their data
        local fakePetProtection = false -- Toggle for re-inserting removed fake pets
        local equippedPet = nil
        local mountedPet = nil
        local currentMountTrack = nil

        -- === STARTUP: Scan inventory for previously created fake pets ===
        pcall(function()
            set_thread_identity(2)
            local inv = clientData.get("inventory")
            set_thread_identity(8)
            if inv and inv.pets then
                for uid, petData in pairs(inv.pets) do
                    if petData._fake then
                        fakePetIds[uid] = petData
                        pets[uid] = {data = petData, model = nil}
                        warn("[FakePet] Recovered fake pet from previous session: " .. tostring(petData.id) .. " (" .. uid .. ")")
                    end
                end
            end
        end)

        local function updateData(key, action)
            local data = clientData.get(key)
            local clonedData = table.clone(data)
            clientData.predict(key, action(clonedData))
        end

        local function getUniqueId()
            local HttpService = game:GetService("HttpService")
            return HttpService:GenerateGUID(false)
        end

        local function getPetModel(kind)
            if petModels[kind] then
                return petModels[kind]
            end
            local streamed = downloader.promise_download_copy("Pets", kind):expect()
            petModels[kind] = streamed
            return streamed
        end

        local function createPet(id, properties)
            local uniqueId = getUniqueId()
            local pet = nil

            set_thread_identity(2)
            updateData(
                "inventory",
                function(inventory)
                    local newPets = table.clone(inventory.pets)
                    local item = items[id]
                    pet = {
                        unique = uniqueId,
                        category = "pets",
                        id = id,
                        kind = item.kind,
                        newness_order = 0,
                        properties = properties,
                        _fake = true -- Marker for fake pet detection
                    }
                    newPets[uniqueId] = pet
                    inventory.pets = newPets
                    return inventory
                end
            )

            set_thread_identity(8)
            pets[uniqueId] = {data = pet, model = nil}
            -- Track this pet as fake for protection
            fakePetIds[uniqueId] = pet
            warn("[FakePet] Created fake pet '" .. tostring(id) .. "' with uniqueId: " .. tostring(uniqueId))
            return pet
        end

        local function neonify(model, entry)
            local petModel = model:FindFirstChild("PetModel")
            if not petModel then
                return
            end
            for neonPart, configuration in pairs(entry.neon_parts) do
                local trueNeonPart = petRigs.get(petModel).get_geo_part(petModel, neonPart)
                trueNeonPart.Material = configuration.Material
                trueNeonPart.Color = configuration.Color
            end
        end

        local function addPetWrapper(wrapper)
            updateData(
                "pet_char_wrappers",
                function(petWrappers)
                    wrapper.unique = #petWrappers + 1
                    wrapper.index = #petWrappers + 1
                    petWrappers[#petWrappers + 1] = wrapper
                    return petWrappers
                end
            )
        end

        local function addPetState(state)
            updateData(
                "pet_state_managers",
                function(petStates)
                    petStates[#petStates + 1] = state
                    return petStates
                end
            )
        end

        local function findIndex(array, finder)
            for index, value in pairs(array) do
                if finder(value, index) then
                    return index
                end
            end
            return nil
        end

        local function removePetWrapper(uniqueId)
            updateData(
                "pet_char_wrappers",
                function(petWrappers)
                    local index =
                        findIndex(
                        petWrappers,
                        function(wrapper)
                            return wrapper.pet_unique == uniqueId
                        end
                    )
                    if not index then
                        return petWrappers
                    end
                    table.remove(petWrappers, index)
                    for wrapperIndex, wrapper in pairs(petWrappers) do
                        wrapper.unique = wrapperIndex
                        wrapper.index = wrapperIndex
                    end
                    return petWrappers
                end
            )
        end

        local function clearPetState(uniqueId)
            local pet = pets[uniqueId]
            if not pet or not pet.model then
                return
            end
            updateData(
                "pet_state_managers",
                function(states)
                    local index =
                        findIndex(
                        states,
                        function(state)
                            return state.char == pet.model
                        end
                    )
                    if not index then
                        return states
                    end
                    local clonedStates = table.clone(states)
                    clonedStates[index] = table.clone(clonedStates[index])
                    clonedStates[index].states = {}
                    return clonedStates
                end
            )
        end

        local function setPetState(uniqueId, id)
            local pet = pets[uniqueId]
            if not pet or not pet.model then
                return
            end
            updateData(
                "pet_state_managers",
                function(states)
                    local index =
                        findIndex(
                        states,
                        function(state)
                            return state.char == pet.model
                        end
                    )
                    if not index then
                        return states
                    end
                    local clonedStates = table.clone(states)
                    clonedStates[index] = table.clone(clonedStates[index])
                    clonedStates[index].states = {{id = id}}
                    return clonedStates
                end
            )
        end

        local function attachPlayerToPet(pet)
            local character = game.Players.LocalPlayer.Character
            if not character or not character.PrimaryPart then
                return false
            end
            local ridePosition = pet:FindFirstChild("RidePosition", true)
            if not ridePosition then
                return false
            end

            local sourceAttachment = Instance.new("Attachment")
            sourceAttachment.Parent = ridePosition
            sourceAttachment.Position = Vector3.new(0, 1.237, 0)
            sourceAttachment.Name = "SourceAttachment"

            local stateConnection = Instance.new("RigidConstraint")
            stateConnection.Name = "StateConnection"
            stateConnection.Attachment0 = sourceAttachment
            stateConnection.Attachment1 = character.PrimaryPart.RootAttachment
            stateConnection.Parent = character
            return true
        end

        local function clearPlayerState()
            updateData(
                "state_manager",
                function(state)
                    local clonedState = table.clone(state)
                    clonedState.states = {}
                    clonedState.is_sitting = false
                    return clonedState
                end
            )
        end

        local function setPlayerState(id)
            updateData(
                "state_manager",
                function(state)
                    local clonedState = table.clone(state)
                    clonedState.states = {{id = id}}
                    clonedState.is_sitting = true
                    return clonedState
                end
            )
        end

        local function removePetState(uniqueId)
            local pet = pets[uniqueId]
            if not pet or not pet.model then
                return
            end
            updateData(
                "pet_state_managers",
                function(petStates)
                    local index =
                        findIndex(
                        petStates,
                        function(state)
                            return state.char == pet.model
                        end
                    )
                    if not index then
                        return petStates
                    end
                    table.remove(petStates, index)
                    return petStates
                end
            )
        end

        local function unmount(uniqueId)
            local pet = pets[uniqueId]
            if not pet or not pet.model then
                return
            end
            if currentMountTrack then
                currentMountTrack:Stop()
                currentMountTrack:Destroy()
            end
            local sourceAttachment = pet.model:FindFirstChild("SourceAttachment", true)
            if sourceAttachment then
                sourceAttachment:Destroy()
            end
            if game.Players.LocalPlayer.Character then
                for _, d in pairs(game.Players.LocalPlayer.Character:GetDescendants()) do
                    if d:IsA("BasePart") and d:GetAttribute("HaveMass") then
                        d.Massless = false
                    end
                end
            end
            clearPetState(uniqueId)
            clearPlayerState()
            pet.model:ScaleTo(1)
            mountedPet = nil
        end

        local function mount(uniqueId, playerState, petState)
            local pet = pets[uniqueId]
            if not pet or not pet.model then
                return
            end
            local player = game.Players.LocalPlayer
            if not player.Character or not player.Character.PrimaryPart then
                return
            end
            mountedPet = uniqueId
            setPetState(uniqueId, petState)
            setPlayerState(playerState)
            pet.model:ScaleTo(2)
            attachPlayerToPet(pet.model)
            currentMountTrack =
                player.Character.Humanoid.Animator:LoadAnimation(animationManager.get_track("PlayerRidingPet"))
            player.Character.Humanoid.Sit = true
            for _, d in pairs(player.Character:GetDescendants()) do
                if d:IsA("BasePart") and d.Massless == false then
                    d.Massless = true
                    d:SetAttribute("HaveMass", true)
                end
            end
            currentMountTrack:Play()
        end

        local function fly(uniqueId)
            mount(uniqueId, "PlayerFlyingPet", "PetBeingFlown")
        end
        local function ride(uniqueId)
            mount(uniqueId, "PlayerRidingPet", "PetBeingRidden")
        end

        local function unequip(item)
            local pet = pets[item.unique]
            if not pet or not pet.model then
                return
            end
            unmount(item.unique)
            removePetWrapper(item.unique)
            removePetState(item.unique)
            pet.model:Destroy()
            pet.model = nil
            equippedPet = nil
        end

        local function equip(item)
            if equippedPet then
                unequip(equippedPet)
            end
            local petModel = getPetModel(item.kind):Clone()
            petModel.Parent = workspace
            pets[item.unique].model = petModel
            if item.properties.neon or item.properties.mega_neon then
                neonify(petModel, items[item.kind])
            end
            equippedPet = item
            addPetWrapper(
                {
                    char = petModel,
                    mega_neon = item.properties.mega_neon,
                    neon = item.properties.neon,
                    player = game.Players.LocalPlayer,
                    entity_controller = game.Players.LocalPlayer,
                    controller = game.Players.LocalPlayer,
                    rp_name = item.properties.rp_name or "",
                    pet_trick_level = item.properties.pet_trick_level,
                    pet_unique = item.unique,
                    pet_id = item.id,
                    location = {
                        full_destination_id = "housing",
                        destination_id = "housing",
                        house_owner = game.Players.LocalPlayer
                    },
                    pet_progression = {
                        friendship_level = item.properties.friendship_level,
                        age = item.properties.age,
                        percentage = 0
                    },
                    are_colors_sealed = false,
                    is_pet = true
                }
            )
            addPetState(
                {
                    char = petModel,
                    player = game.Players.LocalPlayer,
                    store_key = "pet_state_managers",
                    is_sitting = false,
                    chars_connected_to_me = {},
                    states = {}
                }
            )
        end

        local oldGet = router.get
        local function createRemoteFunctionMock(callback)
            return {
                InvokeServer = function(_, ...)
                    return callback(...)
                end
            }
        end
        local function createRemoteEventMock(callback)
            return {
                FireServer = function(_, ...)
                    return callback(...)
                end
            }
        end

        local equipRemote =
            createRemoteFunctionMock(
            function(uniqueId, metadata)
                local pet = pets[uniqueId]
                if not pet then
                    return
                end
                equip(pet.data)
                return true, {action = "equip", is_server = true}
            end
        )
        local unequipRemote =
            createRemoteFunctionMock(
            function(uniqueId)
                local pet = pets[uniqueId]
                if not pet then
                    return
                end
                unequip(pet.data)
                return true, {action = "unequip", is_server = true}
            end
        )
        local rideRemote =
            createRemoteFunctionMock(
            function(item)
                ride(item.pet_unique)
            end
        )
        local flyRemote =
            createRemoteFunctionMock(
            function(item)
                fly(item.pet_unique)
            end
        )
        local unmountRemoteFunction =
            createRemoteFunctionMock(
            function()
                unmount(mountedPet)
            end
        )
        local unmountRemoteEvent =
            createRemoteEventMock(
            function()
                unmount(mountedPet)
            end
        )

        -- === FAKE PET TRADE INTERCEPTORS ===
        local function isFakePet(uid)
            local ok, result = pcall(function()
                set_thread_identity(2)
                local inv = clientData.get("inventory")
                set_thread_identity(8)
                if inv and inv.pets and inv.pets[uid] then
                    return inv.pets[uid]._fake == true
                end
                return false
            end)
            if ok then return result end
            return false
        end

        -- Helper: find TradeApp UI elements
        local function getTradeUI()
            local pg = game.Players.LocalPlayer:FindFirstChild("PlayerGui")
            if not pg then return nil end
            local tradeApp = pg:FindFirstChild("TradeApp")
            if not tradeApp then return nil end
            local mainFrame = tradeApp:FindFirstChild("Frame")
            if not mainFrame then return nil end
            return {
                negotiation = mainFrame:FindFirstChild("NegotiationFrame"),
                confirmation = mainFrame:FindFirstChild("ConfirmationFrame")
            }
        end

        local function getNegMyOfferSlots()
            local ui = getTradeUI()
            if not ui or not ui.negotiation then return nil end
            local body = ui.negotiation:FindFirstChild("Body")
            if not body then return nil end
            local myOffer = body:FindFirstChild("MyOffer")
            if not myOffer then return nil end
            return myOffer:FindFirstChild("Slots")
        end

        local function getConfMyOfferSlots()
            local ui = getTradeUI()
            if not ui or not ui.confirmation then return nil end
            local myOffer = ui.confirmation:FindFirstChild("MyOffer")
            if not myOffer then return nil end
            return myOffer:FindFirstChild("Slots")
        end

        local fakePetSlotClones = {} -- uniqueId -> saved clone for confirmation injection
        local clonedFakePetIds = {} -- uniqueId -> true (prevent duplicate processing)

        -- Re-inject any fake pet clones that are missing from the negotiation UI
        local function reinjectMissingFakePets()
            local slots = getNegMyOfferSlots()
            if not slots then return end

            for fakeId, savedClone in pairs(fakePetSlotClones) do
                -- Check if this fake pet's slot still exists in the UI
                local found = false
                for _, child in ipairs(slots:GetChildren()) do
                    if child:GetAttribute("_fakePet") == fakeId and child.Visible then
                        found = true
                        break
                    end
                end
                if not found then
                    -- Re-inject from saved clone
                    local reClone = savedClone:Clone()
                    reClone:SetAttribute("_fakePet", fakeId)
                    reClone.Visible = true
                    reClone.Parent = slots
                    warn("[TradeIntercept] Re-injected missing pet: " .. fakeId)
                end
            end
        end

        local addItemMock = createRemoteEventMock(function(uniqueId)
            if isFakePet(uniqueId) then
                -- Skip if we already handled this fake pet in this trade
                if clonedFakePetIds[uniqueId] then
                    warn("[TradeIntercept] Already cloned, skipping: " .. tostring(uniqueId))
                    return
                end
                clonedFakePetIds[uniqueId] = true
                warn("[TradeIntercept] BLOCKED: " .. tostring(uniqueId))

                -- Poll to find slot, hide ghosts, and save clone
                task.spawn(function()
                    local cloned = false
                    for attempt = 1, 10 do
                        task.wait(0.05)
                        local slots = getNegMyOfferSlots()
                        if not slots then continue end

                        -- Hide ghost duplicates (same name, one has image, one doesn't)
                        local slotsByName = {}
                        for _, child in ipairs(slots:GetChildren()) do
                            if child:IsA("ImageButton") and child.Name:match("^Slot%d+$") and child.Visible then
                                slotsByName[child.Name] = slotsByName[child.Name] or {}
                                table.insert(slotsByName[child.Name], child)
                            end
                        end
                        for name, list in pairs(slotsByName) do
                            if #list > 1 then
                                local hasImageSlot = false
                                for _, s in ipairs(list) do
                                    if s:FindFirstChild("ItemImageTemplate") then hasImageSlot = true break end
                                end
                                if hasImageSlot then
                                    for _, s in ipairs(list) do
                                        if not s:FindFirstChild("ItemImageTemplate") then
                                            s.Visible = false
                                            s:SetAttribute("_fakeGhost", true)
                                            warn("[TradeIntercept] Hidden ghost: " .. name)
                                        end
                                    end
                                end
                            end
                        end

                        -- Clone the new fake pet's slot (unmarked, has image)
                        if not cloned then
                            for _, child in ipairs(slots:GetChildren()) do
                                if child:IsA("ImageButton") and child.Visible and child.Name:match("^Slot%d+$") then
                                    if child:FindFirstChild("ItemImageTemplate") and not child:GetAttribute("_fakePet") then
                                        child:SetAttribute("_fakePet", uniqueId)
                                        fakePetSlotClones[uniqueId] = child:Clone()
                                        cloned = true
                                        warn("[TradeIntercept] Saved clone for: " .. uniqueId)
                                        break
                                    end
                                end
                            end
                        end

                        if cloned then break end
                    end

                    if not cloned then
                        warn("[TradeIntercept] WARNING: Could not find slot after 10 attempts")
                    end

                    -- After cloning, re-inject any previously saved fake pets removed by UI rebuild
                    task.wait(0.1)
                    reinjectMissingFakePets()
                end)

                return
            end
            oldGet("TradeAPI/AddItemToOffer"):FireServer(uniqueId)
        end)

        local removeItemMock = createRemoteEventMock(function(uniqueId)
            if isFakePet(uniqueId) then
                warn("[TradeIntercept] BLOCKED RemoveItemFromOffer for fake pet: " .. tostring(uniqueId))
                return
            end
            oldGet("TradeAPI/RemoveItemFromOffer"):FireServer(uniqueId)
        end)

        -- === CONFIRMATION STAGE INJECTION ===
        task.spawn(function()
            local pg = game.Players.LocalPlayer:WaitForChild("PlayerGui")

            local function setupConfirmationWatcher()
                local ui = getTradeUI()
                if not ui then
                    warn("[TradeInject] getTradeUI returned nil")
                    return
                end
                if not ui.confirmation then
                    warn("[TradeInject] ConfirmationFrame not found")
                    return
                end

                warn("[TradeInject] Watcher connected to ConfirmationFrame.Visible")

                ui.confirmation:GetPropertyChangedSignal("Visible"):Connect(function()
                    -- When confirmation CLOSES, clean up for next trade
                    if not ui.confirmation.Visible then
                        fakePetSlotClones = {}
                        clonedFakePetIds = {}
                        -- Remove our injected fake slots from confirmation
                        local confSlots = getConfMyOfferSlots()
                        if confSlots then
                            for _, child in ipairs(confSlots:GetChildren()) do
                                if child:GetAttribute("_injectedFake") then
                                    child:Destroy()
                                end
                            end
                        end
                        -- Destroy all our injected/modified elements in negotiation
                        local negSlots = getNegMyOfferSlots()
                        if negSlots then
                            for _, child in ipairs(negSlots:GetChildren()) do
                                if child:GetAttribute("_fakePet") or child:GetAttribute("_fakeGhost") then
                                    child:Destroy()
                                end
                            end
                        end
                        warn("[TradeInject] Trade closed - cleaned up")
                        return
                    end

                    -- Count clones
                    local cloneCount = 0
                    for _ in pairs(fakePetSlotClones) do cloneCount = cloneCount + 1 end
                    warn("[TradeInject] Confirmation opened! Clones: " .. cloneCount)
                    if cloneCount == 0 then return end

                    local confSlots = getConfMyOfferSlots()
                    if not confSlots then
                        warn("[TradeInject] ConfirmationFrame Slots not found!")
                        return
                    end

                    -- Inject all saved clones into confirmation
                    local i = 0
                    for fakeId, savedClone in pairs(fakePetSlotClones) do
                        i = i + 1
                        local clone = savedClone:Clone()
                        clone.Name = "Slot" .. i
                        clone.Visible = true
                        clone:SetAttribute("_fakePet", nil)
                        clone:SetAttribute("_injectedFake", true)
                        local removeIcon = clone:FindFirstChild("RemoveIcon")
                        if removeIcon then removeIcon.Visible = false end
                        local addItem = clone:FindFirstChild("AddItem")
                        if addItem then addItem.Visible = false end
                        clone.Parent = confSlots
                        warn("[TradeInject] Added: " .. clone.Name .. " (" .. fakeId .. ")")
                    end

                    warn("[TradeInject] Done! Injected " .. cloneCount)
                end)

                -- Clones are now cleared when confirmation closes (see above)
            end

            local function onTradeApp(tradeApp)
                local ok, err = pcall(setupConfirmationWatcher)
                if not ok then
                    warn("[TradeInject] Setup error: " .. tostring(err))
                end
            end

            local existing = pg:FindFirstChild("TradeApp")
            if existing then
                warn("[TradeInject] TradeApp already exists, setting up watcher")
                onTradeApp(existing)
            end
            pg.ChildAdded:Connect(function(child)
                if child.Name == "TradeApp" then
                    task.wait(0.5)
                    warn("[TradeInject] TradeApp appeared, setting up watcher")
                    onTradeApp(child)
                end
            end)
        end)

        router.get = function(name)
            if name == "ToolAPI/Equip" then
                return equipRemote
            end
            if name == "ToolAPI/Unequip" then
                return unequipRemote
            end
            if name == "AdoptAPI/RidePet" then
                return rideRemote
            end
            if name == "AdoptAPI/FlyPet" then
                return flyRemote
            end
            if name == "AdoptAPI/ExitSeatStatesYield" then
                return unmountRemoteFunction
            end
            if name == "AdoptAPI/ExitSeatStates" then
                return unmountRemoteEvent
            end
            if name == "TradeAPI/AddItemToOffer" then
                return addItemMock
            end
            if name == "TradeAPI/RemoveItemFromOffer" then
                return removeItemMock
            end
            return oldGet(name)
        end

        for _, charWrapper in pairs(clientData.get("pet_char_wrappers")) do
            oldGet("ToolAPI/Unequip"):InvokeServer(charWrapper.pet_unique)
        end

        local Loads = require(game.ReplicatedStorage.Fsys).load
        local InventoryDB = Loads("InventoryDB")

        function GetPetByName(name)
            for i, v in pairs(InventoryDB.pets) do
                if v.name:lower() == name:lower() then
                    return v.id
                end
            end
            return false
        end

        -- OwO Hub Loading Screen (runs in parallel)
        local Players = game:GetService("Players")
        local TweenService = game:GetService("TweenService")
        local lp = Players.LocalPlayer
        local pg = lp:WaitForChild("PlayerGui")

        local loadGui = Instance.new("ScreenGui")
        loadGui.Name = "OwOLoader"
        loadGui.ResetOnSpawn = false
        loadGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
        loadGui.DisplayOrder = 999
        loadGui.Parent = pg

        -- Background (compact card)
        local bg = Instance.new("Frame")
        bg.Size = UDim2.new(0, 320, 0, 160)
        bg.Position = UDim2.new(0.5, 0, 0.5, 0)
        bg.AnchorPoint = Vector2.new(0.5, 0.5)
        bg.BackgroundColor3 = Color3.fromHex("#1a1a2e")
        bg.BorderSizePixel = 0
        bg.Parent = loadGui

        local bgCorner = Instance.new("UICorner")
        bgCorner.CornerRadius = UDim.new(0, 12)
        bgCorner.Parent = bg

        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, 0, 0, 35)
        title.Position = UDim2.new(0, 0, 0, 15)
        title.BackgroundTransparency = 1
        title.Text = "OwO Hub"
        title.TextColor3 = Color3.fromHex("#ff6b9d")
        title.TextSize = 28
        title.Font = Enum.Font.GothamBold
        title.Parent = bg

        local subtitle = Instance.new("TextLabel")
        subtitle.Size = UDim2.new(1, 0, 0, 20)
        subtitle.Position = UDim2.new(0, 0, 0, 50)
        subtitle.BackgroundTransparency = 1
        subtitle.Text = "Loading..."
        subtitle.TextColor3 = Color3.fromHex("#ffffff")
        subtitle.TextTransparency = 0.4
        subtitle.TextSize = 14
        subtitle.Font = Enum.Font.Gotham
        subtitle.Parent = bg

        local barBg = Instance.new("Frame")
        barBg.Size = UDim2.new(0, 280, 0, 6)
        barBg.Position = UDim2.new(0.5, 0, 0, 95)
        barBg.AnchorPoint = Vector2.new(0.5, 0)
        barBg.BackgroundColor3 = Color3.fromHex("#2a2a4a")
        barBg.BorderSizePixel = 0
        barBg.Parent = bg

        local barCorner = Instance.new("UICorner")
        barCorner.CornerRadius = UDim.new(0, 3)
        barCorner.Parent = barBg

        local barFill = Instance.new("Frame")
        barFill.Size = UDim2.new(0, 0, 1, 0)
        barFill.BackgroundColor3 = Color3.fromHex("#ff6b9d")
        barFill.BorderSizePixel = 0
        barFill.Parent = barBg

        local fillCorner = Instance.new("UICorner")
        fillCorner.CornerRadius = UDim.new(0, 3)
        fillCorner.Parent = barFill

        local barGradient = Instance.new("UIGradient")
        barGradient.Color = ColorSequence.new(Color3.fromHex("#ff6b9d"), Color3.fromHex("#c850c0"))
        barGradient.Parent = barFill

        local pctText = Instance.new("TextLabel")
        pctText.Size = UDim2.new(1, 0, 0, 20)
        pctText.Position = UDim2.new(0, 0, 0, 110)
        pctText.BackgroundTransparency = 1
        pctText.Text = "0%"
        pctText.TextColor3 = Color3.fromHex("#ffffff")
        pctText.TextTransparency = 0.3
        pctText.TextSize = 13
        pctText.Font = Enum.Font.GothamMedium
        pctText.Parent = bg

        -- Animate loading (sequential, waits before opening UI)
        pcall(function()
            local steps = {
                {pct = 12, msg = "Connecting...", wait = 0.6},
                {pct = 25, msg = "Loading modules...", wait = 0.7},
                {pct = 40, msg = "Loading pets database...", wait = 0.8},
                {pct = 55, msg = "Initializing UI...", wait = 0.7},
                {pct = 70, msg = "Loading assets...", wait = 0.7},
                {pct = 85, msg = "Preparing hub...", wait = 0.7},
                {pct = 100, msg = "Ready!", wait = 0.5},
            }
            for _, step in ipairs(steps) do
                TweenService:Create(barFill, TweenInfo.new(step.wait, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Size = UDim2.new(step.pct / 100, 0, 1, 0)
                }):Play()
                pctText.Text = step.pct .. "%"
                subtitle.Text = step.msg
                task.wait(step.wait)
            end
            task.wait(0.3)
        end)
        pcall(function() loadGui:Destroy() end)

        local WindUI =
            loadstring(game:HttpGet("https://raw.githubusercontent.com/ofkotov/lib/refs/heads/main/123"))()

        local Window =
            WindUI:CreateWindow(
            {
                Title = "OwO Hub",
                Icon = "cat",
                Author = "by @mkllx",
                Folder = "OwOHub",
                Size = UDim2.fromOffset(420, 350),
                Transparent = false,
                Theme = "Rose",
                User = {
                    Enabled = false,
                    Callback = function()
                    end,
                    Anonymous = false
                },
                SideBarWidth = 150,
                ScrollBarEnabled = true
            }
        )

        Window:EditOpenButton(
            {
                Title = "Open OwO",
                Icon = "rbxassetid://4483345998",
                CornerRadius = UDim.new(0, 16),
                StrokeThickness = 2,
                Color = ColorSequence.new(Color3.fromHex("ff6b9d"), Color3.fromHex("c850c0")),
                OnlyMobile = false,
                Enabled = true,
                Draggable = true
            }
        )

        Window:SetToggleKey(Enum.KeyCode.K)


        local PetsTab =
            Window:Tab(
            {
                Title = "Pets",
                Icon = "paw-print",
                Desc = "Spawn any pet owo"
            }
        )


        local petName = nil
        local petType = "FR"
        local petCount = 1
        local petRarity = "All"

        PetsTab:Paragraph(
            {
                Title = "Pet Spawner",
                Desc = "Enter the pet name and choose pet type before spawning",
                Image = "heart",
                Color = "HotPink"
            }
        )

        PetsTab:Input(
            {
                Title = "Pet Name",
                Value = "",
                InputIcon = "search",
                Placeholder = "Enter text...",
                Callback = function(input)
                    task.spawn(
                        function()
                            petName = input
                            warn("Pet name set to:", petName)
                        end
                    )
                end
            }
        )

        PetsTab:Dropdown(
            {
                Title = "Type",
                Values = {"FR", "NFR", "MFR"},
                Multi = false,
                Default = "FR",
                Callback = function(value)
                    task.spawn(
                        function()
                            if value == nil then return end
                            petType = value
                            warn("Pet type set to:", petType)
                        end
                    )
                end
            }
        )

        PetsTab:Input(
            {
                Title = "Amount",
                Value = "1",
                InputIcon = "hash",
                Placeholder = "Enter number...",
                Callback = function(input)
                    task.spawn(
